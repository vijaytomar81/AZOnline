{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "lib": [
      "ES2020",
      "DOM"
    ],
    "moduleResolution": "node",
    "types": [
      "node",
      "@playwright/test"
    ],
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "baseUrl": ".",
    "paths": {
      "@/*": [
        "src/*"
      ],
      "@core/*": [
        "src/core/*"
      ],
      "@automation/*": [
        "src/automation/*"
      ],
      "@pageObjects/*": [
        "src/pageObjects/*"
      ],
      "@page-maps/*": [
        "src/pageObjects/maps/*"
      ],
      "@page-objects/*": [
        "src/pageObjects/objects/*"
      ],
      "@page-manifest/*": [
        "src/pageObjects/.manifest/*"
      ],
      "@pageActions/*": [
        "src/pageActions/*"
      ],
      "@pageObjectTools/*": [
        "src/pageObjectTools/*"
      ],
      "@utils/*": [
        "src/utils/*"
      ],
      "@dataLayer/*": [
        "src/dataLayer/*"
      ],
      "@executionLayer/*": [
        "src/executionLayer/*"
      ],
      "@businessJourneys/*": [
        "src/businessJourneys/*"
      ],
      "@config/*": [
        "src/config/*"
      ],
      "@logging/*": [
        "src/logging/*"
      ],
      "@evidence/*": [
        "src/evidence/*"
      ]
    }
  },
  "include": [
    "src",
    "playwright.config.ts"
  ]
}