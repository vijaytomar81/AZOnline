{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "lib": [
      "ES2020",
      "DOM"
    ],
    "moduleResolution": "node",
    "types": [
      "node",
      "@playwright/test"
    ],
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "baseUrl": ".",
    "ignoreDeprecations": "5.0",
    "paths": {
      "@/*": [
        "src/*"
      ],
      "@frameworkCore/*": [
        "src/frameworkCore/*"
      ],
      "@businessLayer/*": [
        "src/businessLayer/*"
      ],
      "@configLayer/*": [
        "src/configLayer/*"
      ],
      "@dataLayer/*": [
        "src/dataLayer/*"
      ],
      "@evidenceLayer": [
        "src/evidenceLayer/index.ts"
      ],
      "@evidenceLayer/*": [
        "src/evidenceLayer/*"
      ],
      "@evidenceFactory": [
        "src/evidenceFactory/index.ts"
      ],
      "@evidenceFactory/*": [
        "src/evidenceFactory/*"
      ],
      "@integrations/*": [
        "src/integrations/*"
      ],
      "@toolingLayer/*": [
        "src/toolingLayer/*"
      ],
      "@utils/*": [
        "src/utils/*"
      ]
    }
  },
  "include": [
    "src",
    "playwright.config.ts"
  ]
}