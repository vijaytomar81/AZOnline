{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "lib": [
      "ES2020",
      "DOM"
    ],
    "moduleResolution": "node",
    "types": [
      "node",
      "@playwright/test"
    ],
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "baseUrl": ".",
    "paths": {
      "@/*": [
        "src/*"
      ],
      "@pages/*": [
        "src/pages/*"
      ],
      "@page-maps/*": [
        "src/pages/maps/*"
      ],
      "@page-objects/*": [
        "src/pages/objects/*"
      ],
      "@page-manifest/*": [
        "src/pages/.manifest/*"
      ]
    }
  },
  "include": [
    "src",
    "playwright.config.ts"
  ]
}