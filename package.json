{
  "name": "azonline",
  "version": "1.0.0",
  "main": "index.js",
  "scripts": {
    "data:build": "ts-node src/data/data-builder/index.ts",
    "data:build:verbose": "ts-node src/data/data-builder/index.ts -- --verbose",
    "data:build:empty": "ts-node src/data/data-builder/index.ts -- --includeEmptyChildFields true",
    "data:build:empty:verbose": "ts-node src/data/data-builder/index.ts -- --includeEmptyChildFields true --verbose",
    "data:build:flowNB": "ts-node src/data/data-builder/index.ts -- --sheet FlowNB",
    "data:build:debug": "ts-node src/data/data-builder/index.ts -- --includeEmptyChildFields true --verbose",

    "test:e2e": "playwright test",
    "e2e": "npm run data:build -- && npm run test:e2e",

    "scan:page": "ts-node src/scanner/commands/scan.ts",
    "scan:page:verbose": "ts-node src/scanner/commands/scan.ts -- --verbose",
    "scan:page:merge": "ts-node src/scanner/commands/scan.ts -- --merge",
    "scan:page:merge:verbose": "ts-node src/scanner/commands/scan.ts -- --merge --verbose",

    "gen:elements": "ts-node src/scanner/commands/generate.ts -- --merge",
    "gen:elements:verbose": "ts-node src/scanner/commands/generate.ts -- --merge --verbose",

    "gen:elements:changed": "ts-node src/scanner/commands/generate.ts -- --changedOnly --merge",
    "gen:elements:changed:verbose": "ts-node src/scanner/commands/generate.ts -- --changedOnly --merge --verbose",

    "gen:elements:noScaffold": "ts-node src/scanner/commands/generate.ts -- --merge --noScaffold",
    "gen:elements:changed:noScaffold": "ts-node src/scanner/commands/generate.ts -- --changedOnly --merge --noScaffold",
    
    "gen:hashes": "ts-node src/scanner/commands/generate.ts -- --stateOnly --verbose",
    "gen:hashes:changed": "ts-node src/scanner/commands/generate.ts -- --changedOnly --stateOnly --verbose"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/vijaytomar81/AZOnline.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/vijaytomar81/AZOnline/issues"
  },
  "homepage": "https://github.com/vijaytomar81/AZOnline#readme",
  "description": "",
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@types/node": "^25.3.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "exceljs": "^4.1.1"
  }
}