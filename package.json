{
  "name": "azonline",
  "version": "1.0.0",
  "main": "index.js",
  "scripts": {
    "data:build": "ts-node src/data/data-builder/index.ts",
    "data:build:verbose": "ts-node src/data/data-builder/index.ts -- --verbose",
    "data:build:empty": "ts-node src/data/data-builder/index.ts -- --includeEmptyChildFields true",
    "data:build:empty:verbose": "ts-node src/data/data-builder/index.ts -- --includeEmptyChildFields true --verbose",
    "data:build:flowNB": "ts-node src/data/data-builder/index.ts -- --sheet FlowNB",
    "data:build:debug": "ts-node src/data/data-builder/index.ts -- --includeEmptyChildFields true --verbose",
    "data:build:help": "ts-node src/data/data-builder/index.ts -- --help",
    
    "test:e2e": "playwright test",
    "e2e": "npm run data:build -- && npm run test:e2e",

    "scanner": "node -r ts-node/register src/scanner/cli.ts",

    "scan:page": "npm run scanner -- scan",
    "scan:page:verbose": "npm run scanner -- scan --verbose",
    "scan:page:merge": "npm run scanner -- scan --merge",
    "scan:page:merge:verbose": "npm run scanner -- scan --merge --verbose",

    "gen:elements": "npm run scanner -- generate --merge",
    "gen:elements:verbose": "npm run scanner -- generate --merge --verbose",
    "gen:elements:changed": "npm run scanner -- generate --changedOnly --merge",
    "gen:elements:changed:verbose": "npm run scanner -- generate --changedOnly --merge --verbose",
    "gen:elements:noScaffold": "npm run scanner -- generate --merge --noScaffold",
    "gen:elements:changed:noScaffold": "npm run scanner -- generate --changedOnly --merge --noScaffold",
    "gen:hashes": "npm run scanner -- generate --stateOnly --verbose",
    "gen:hashes:changed": "npm run scanner -- generate --changedOnly --stateOnly --verbose",

    "scanner:validate": "npm run scanner -- validate",
    "scanner:validate:verbose": "npm run scanner -- validate --verbose",

    "scanner:repair": "npm run scanner -- repair",
    "scanner:doctor": "npm run scanner -- doctor",
    "scanner:tsc": "tsc -p tsconfig.scanner.json --noEmit",

    "scanner:help": "npm run scanner -- help"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/vijaytomar81/AZOnline.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/vijaytomar81/AZOnline/issues"
  },
  "homepage": "https://github.com/vijaytomar81/AZOnline#readme",
  "description": "",
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@types/node": "^25.3.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "exceljs": "^4.1.1"
  }
}