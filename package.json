{
  "name": "azonline",
  "version": "1.0.0",
  "main": "index.js",
"scripts": {
  "test:e2e": "playwright test",
  "e2e": "npm run data:build -- && npm run test:e2e",

  "data": "node -r ts-node/register -r tsconfig-paths/register src/dataLayer/builder/index.ts",
  "data:build": "npm run data --",
  "data:build:verbose": "npm run data -- --verbose",
  "data:build:strict": "npm run data -- --strictValidation",
  "data:build:strict:verbose": "npm run data -- --strictValidation --verbose",
  "data:build:noEmpty": "npm run data -- --excludeEmptyFields",
  "data:build:noEmpty:verbose": "npm run data -- --excludeEmptyFields --verbose",
  "data:build:noEmpty:strict": "npm run data -- --excludeEmptyFields --strictValidation",
  "data:build:noEmpty:strict:verbose": "npm run data -- --excludeEmptyFields --strictValidation --verbose",
  "data:help": "npm run data -- --help",

  "data:nb:athena:azonline:motor": "npm run data:build -- --excel \"sampleData/New Business.xlsx\" --sheet \"FlowNB\" --platform \"Athena\" --application \"AzOnline\" --product \"Motor\" --journeyContext \"NewBusiness\"",
  "data:nb:pcw:ctm:motor": "npm run data:build -- --excel \"sampleData/New Business.xlsx\" --sheet \"FlowNB\" --platform \"PCW\" --application \"CTM\" --product \"Motor\" --journeyContext \"NewBusiness\"",
  "data:nb:pcwtool:ctm:motor": "npm run data:build -- --excel \"sampleData/New Business.xlsx\" --sheet \"PCW-Tool\" --platform \"PCWTool\" --application \"CTM\" --product \"Motor\" --journeyContext \"NewBusiness\"",

  "data:verbose:nb:athena:azonline:motor": "npm run data:build -- --excel \"sampleData/New Business.xlsx\" --sheet \"FlowNB\" --platform \"Athena\" --application \"AzOnline\" --product \"Motor\" --journeyContext \"NewBusiness\" --verbose",
  "data:verbose:nb:pcw:ctm:motor": "npm run data:build -- --excel \"sampleData/New Business.xlsx\" --sheet \"FlowNB\" --platform \"PCW\" --application \"CTM\" --product \"Motor\" --journeyContext \"NewBusiness\" --verbose",
  "data:verbose:nb:pcwtool:ctm:motor": "npm run data:build -- --excel \"sampleData/New Business.xlsx\" --sheet \"PCW-Tool\" --platform \"PCWTool\" --application \"CTM\" --product \"Motor\" --journeyContext \"NewBusiness\" --verbose",

  "execution": "node -r ts-node/register -r tsconfig-paths/register src/frameworkCore/executionLayer/cli/main.ts",
  "execution:run": "npm run execution --",
  "execution:verbose": "npm run execution -- --verbose",
  "execution:help": "npm run execution -- --help",

  "smoke:direct": "npm run execution -- --mode data --platform Athena --application AzOnline --product Motor --journeyContext NewBusiness",
  "smoke:pcw": "npm run execution -- --mode data --platform PCW --application CTM --product Motor --journeyContext NewBusiness",
  "smoke:pcwtool": "npm run execution -- --mode data --platform PCWTool --application CTM --product Motor --journeyContext NewBusiness",

  "smoke:e2e": "npm run execution -- --mode e2e --excel \"sampleData/E2E Scenarios.xlsx\" --sheet \"Scenarios\" --platform Athena --application AzOnline --product Motor",

  "smoke:verbose:direct": "npm run execution -- --mode data --platform Athena --application AzOnline --product Motor --journeyContext NewBusiness --verbose",
  "smoke:verbose:pcw": "npm run execution -- --mode data --platform PCW --application CTM --product Motor --journeyContext NewBusiness --verbose",
  "smoke:verbose:pcwtool": "npm run execution -- --mode data --platform PCWTool --application CTM --product Motor --journeyContext NewBusiness --verbose",
  "smoke:verbose:e2e": "npm run execution -- --mode e2e --excel \"sampleData/E2E Scenarios.xlsx\" --sheet \"Scenarios\" --platform Athena --application AzOnline --product Motor --verbose",

  "smoke:direct:loop": "npm run execution -- --mode data --platform Athena --application AzOnline --product Motor --journeyContext NewBusiness --iterations 2 --verbose",
  "smoke:pcw:loop": "npm run execution -- --mode data --platform PCW --application CTM --product Motor --journeyContext NewBusiness --iterations 2 --verbose",
  "smoke:pcwtool:loop": "npm run execution -- --mode data --platform PCWTool --application CTM --product Motor --journeyContext NewBusiness --iterations 2 --verbose",

  "smoke:mta:add-driver": "npm run execution -- --mode data --platform Athena --application AzOnline --product Motor --journeyContext MTA --journeySubType AddDriver",

  "smoke:help": "npm run execution -- --mode e2e --help",
  "smoke:data:help": "npm run execution -- --mode data --help",

  "scan:cli": "node -r ts-node/register -r tsconfig-paths/register src/toolingLayer/pageScanner/cli.ts",
  "scan:page": "npm run scan:cli -- scan",
  "scan:page:verbose": "npm run scan:cli -- scan --verbose",
  "scan:page:merge": "npm run scan:cli -- scan --merge",
  "scan:page:merge:verbose": "npm run scan:cli -- scan --merge --verbose",
  "scan:help": "npm run scan:cli -- help",

  "pageobjects:cli": "node -r ts-node/register -r tsconfig-paths/register src/toolingLayer/pageObjects/generator/cli.ts",
  "pageobjects:generate": "npm run pageobjects:cli -- generate --merge",
  "pageobjects:generate:verbose": "npm run pageobjects:cli -- generate --merge --verbose",
  "pageobjects:generate:changed": "npm run pageobjects:cli -- generate --changedOnly --merge",
  "pageobjects:generate:changed:verbose": "npm run pageobjects:cli -- generate --changedOnly --merge --verbose",
  "pageobjects:help": "npm run pageobjects:cli -- help",

  "pageobjects:validate:cli": "node -r ts-node/register -r tsconfig-paths/register src/toolingLayer/pageObjects/validator/cli.ts",
  "pageobjects:validate": "npm run pageobjects:validate:cli -- validate",
  "pageobjects:validate:verbose": "npm run pageobjects:validate:cli -- validate --verbose",
  "pageobjects:validate:strict": "npm run pageobjects:validate:cli -- validate --strict",
  "pageobjects:validate:strict:verbose": "npm run pageobjects:validate:cli -- validate --strict --verbose",
  "pageobjects:validate:help": "npm run pageobjects:validate:cli -- help",

  "pageobjects:repair:cli": "node -r ts-node/register -r tsconfig-paths/register src/toolingLayer/pageObjects/repair/cli.ts",
  "pageobjects:repair": "npm run pageobjects:repair:cli -- repair",
  "pageobjects:repair:verbose": "npm run pageobjects:repair:cli -- repair --verbose",
  "pageobjects:repair:help": "npm run pageobjects:repair:cli -- help",

  "pageactions:generate:cli": "node -r ts-node/register -r tsconfig-paths/register src/toolingLayer/pageActions/generator/cli/runPageActionGenerator.ts",
  "pageactions:generate": "npm run pageactions:generate:cli",
  "pageactions:generate:verbose": "npm run pageactions:generate:cli -- --verbose",

  "pageactions:validate:cli": "node -r ts-node/register -r tsconfig-paths/register src/toolingLayer/pageActions/validator/cli.ts",
  "pageactions:validate": "npm run pageactions:validate:cli -- validate",
  "pageactions:validate:verbose": "npm run pageactions:validate:cli -- validate --verbose",
  "pageactions:validate:strict": "npm run pageactions:validate:cli -- validate --strict",

  "pageactions:repair:cli": "node -r ts-node/register -r tsconfig-paths/register src/toolingLayer/pageActions/repair/cli.ts",
  "pageactions:repair": "npm run pageactions:repair:cli -- repair",
  "pageactions:repair:verbose": "npm run pageactions:repair:cli -- repair --verbose",

  "businessjourney:generate:cli": "node -r ts-node/register -r tsconfig-paths/register src/toolingLayer/businessJourneys/generator/cli.ts",
  "businessjourney:generate": "npm run businessjourney:generate:cli",
  "businessjourney:generate:verbose": "npm run businessjourney:generate:cli -- --verbose",

  "headers:check": "node -r ts-node/register -r tsconfig-paths/register src/toolingLayer/quality/fileHeaderChecker/cli.ts --checkMode",
  "headers:fix": "node -r ts-node/register -r tsconfig-paths/register src/toolingLayer/quality/fileHeaderChecker/cli.ts",

  "check:types": "tsc --noEmit",
  "tools:tsc": "tsc -p tsconfig.tools.json --noEmit",
  "check:dead": "ts-prune",

  "ci:check": "npm run check:types && npm run tools:tsc && npm run headers:check && npm run pageobjects:validate",
  "ci:check:verbose": "npm run check:types && npm run tools:tsc && npm run headers:check && npm run pageobjects:validate:verbose",

  "results:clean": "node scripts/clean-results.js",
  "reports:clean": "node scripts/clean-reports.js",
  "allure:generate": "allure generate results/allure-results -o reports/allure-report --clean",
  "allure:open": "allure open reports/allure-report",
  "allure:serve": "allure serve results/allure-results",
  "e2e:report": "npm run allure:generate"
},
  "repository": {
    "type": "git",
    "url": "git+https://github.com/vijaytomar81/AZOnline.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/vijaytomar81/AZOnline/issues"
  },
  "homepage": "https://github.com/vijaytomar81/AZOnline#readme",
  "description": "",
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@types/node": "^25.3.0",
    "@types/xml2js": "^0.4.14",
    "allure-playwright": "^3.5.0",
    "ts-node": "^10.9.2",
    "ts-prune": "^0.10.3",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "@google-cloud/local-auth": "^3.0.1",
    "exceljs": "^4.1.1",
    "googleapis": "^171.4.0",
    "xml2js": "^0.6.2"
  }
}