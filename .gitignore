# ------------------------------------------------------------
# Node
# ------------------------------------------------------------
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ------------------------------------------------------------
# OS
# ------------------------------------------------------------
.DS_Store
Thumbs.db

# ------------------------------------------------------------
# Environment files
# ------------------------------------------------------------
.env
.env.local
.env.*
!.env.example

# ------------------------------------------------------------
# Build outputs (root only)
# ------------------------------------------------------------
/dist/
/build/
/coverage/

# ------------------------------------------------------------
# Test outputs (generated)
# ------------------------------------------------------------

# Playwright outputs
/results/**
!/results/**/.gitkeep

test-results/
playwright-report/

# Allure generated HTML
reports/allure-report/**
!reports/allure-report/.gitkeep

# Generated reports (Excel)
reports/excel/**
!reports/excel/.gitkeep

/artifacts/**

# ------------------------------------------------------------
# Logs
# ------------------------------------------------------------
*.log

# ------------------------------------------------------------
# TypeScript
# ------------------------------------------------------------
*.tsbuildinfo

# ------------------------------------------------------------
# IDE
# ------------------------------------------------------------
.vscode/
.idea/

# ------------------------------------------------------------
# Optional temp/cache
# ------------------------------------------------------------
.tmp/
.cache/

# ------------------------------------------------------------
# Gmail / Google API credentials (explicit only)
# ------------------------------------------------------------
credentials.json
token.json

# Safer config handling
config/credentials.json
config/token.json
!config/.gitkeep
!config/*.example.json

# ------------------------------------------------------------
# Data Builder (generated data + manifest)
# ------------------------------------------------------------

# Ignore all generated data
src/data/generated/**
src/data/generated/archive/**

# Keep folder structure
!src/data/generated/.gitkeep
!src/data/generated/**/.gitkeep

# Explicitly ignore manifest/index
src/data/generated/index.json
